{
	"name": "mom-convex",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.23.0",
	"scripts": {
		"dev": "concurrently -n next,convex -c blue,green \"pnpm:dev:next\" \"pnpm:dev:convex\"",
		"dev:next": "next dev",
		"dev:convex": "convex dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check . && eslint convex",
		"lint:fix": "biome check --write . && eslint convex --fix",
		"lint:ddd": "eslint convex",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:smoke": "vitest run test/smoke",
		"test:e2e": "playwright test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.71",
		"@ai-sdk/deepseek": "2.0.29",
		"@ai-sdk/google": "^3.0.64",
		"@auth/core": "^0.37.4",
		"@convex-dev/agent": "^0.6.1",
		"@convex-dev/auth": "^0.0.91",
		"@djpanda/convex-authz": "^0.1.7",
		"@djpanda/convex-tenants": "^0.1.6",
		"@vercel/sandbox": "^1.10.0",
		"ai": "^6.0.168",
		"convex": "^1.18.0",
		"convex-helpers": "^0.1.114",
		"next": "^15.1.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@ai-sdk/provider": "3.0.8",
		"@biomejs/biome": "^1.9.4",
		"@edge-runtime/vm": "^5.0.0",
		"@playwright/test": "^1.49.0",
		"@types/node": "^22.10.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@typescript-eslint/parser": "^8.58.2",
		"concurrently": "^9.1.0",
		"convex-test": "^0.0.49",
		"eslint": "^10.2.1",
		"globals": "^17.5.0",
		"msw": "^2.13.4",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.58.2",
		"vitest": "^2.1.0",
		"yaml": "^2.6.0"
	}
}
