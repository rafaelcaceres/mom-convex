# Convex (generated by `pnpm convex dev` on first run)
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=
NEXT_PUBLIC_CONVEX_URL=

# Auth (M0-T02)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
JWT_PRIVATE_KEY=

# Credentials master key (M0-T06)
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
CREDS_MASTER_KEY=

# Slack OAuth (M1-T05)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# LLM (M2)
ANTHROPIC_API_KEY=

# Vercel Sandbox (M2-T11)
# All 3 required in non-Vercel hosting (our Convex deployment). Set via
# `pnpm exec convex env set VERCEL_TOKEN …` — .env.local is for Next.js
# only; Convex has its own deployment env.
# Docs: https://vercel.com/docs/vercel-sandbox/concepts/authentication
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# OpenAI embeddings (M3-T01)
OPENAI_EMBEDDING_KEY=

# Google OAuth (M3-T07)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Notion OAuth (M3-T08)
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# Site URL (Next.js)
SITE_URL=http://localhost:3000
